{
    "app-id": "org.filmulator.Filmulator",
    "runtime": "org.kde.Platform",
    "runtime-version": "5.15-25.08",
    "sdk": "org.kde.Sdk",
    "command": "filmulator",
    "rename-desktop-file": "filmulator.desktop",
    "rename-icon": "filmulator64icon",
    "finish-args": [
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=ipc",
        "--device=dri",
        "--filesystem=home",
        /* Allow other instances to see lockfiles */
        "--env=TMPDIR=/var/tmp",
        "--env=APPDIR=/app/share/Filmulator/qml/filmulator-gui",
        "--env=QT_AUTO_SCREEN_SCALE_FACTOR=1"
    ],
    "cleanup": [
        "/include",
        "/man",
        "/share/man",
        "/lib/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "lensfun",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_POLICY_VERSION_MINIMUM=3.5",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DBUILD_FOR_SSE=0",
                "-DBUILD_FOR_SSE2=0"
            ],
            "cleanup": [
                "/bin",
                "/lib/python3*",
                "*.so"
            ],
            "build-options": {
                "arch": {
                    "x86_64": {
                        "config-opts": [
                            "-DBUILD_FOR_SSE=1",
                            "-DBUILD_FOR_SSE2=1"
                        ]
                    }
                }
            },
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/lensfun/lensfun.git",
                    "commit": "79ff00ad8c5524a0264f554e116edd79e2b241d7"
                }
            ]
        },
        {
            "name": "exiv2",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DEXIV2_BUILD_DOC:BOOL=OFF",
                "-DEXIV2_BUILD_EXIV2_COMMAND=OFF",
                "-DEXIV2_ENABLE_INIH=OFF",
                "-DEXIV2_BUILD_SAMPLES=OFF"
            ],
            "cleanup": [
                "/lib/cmake",
                "*.so"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/Exiv2/exiv2/archive/refs/tags/v0.28.8.tar.gz",
                    "sha256": "ea51b0609f58a9afa063b60daa1539948b62247721e154f4fff0ad3aec9f9756"
                }
            ]
        },
        {
            "name": "libraw",
            "builddir": true,
            "config-opts": [
                "--disable-examples"
            ],
            "cleanup": [
                "/share/doc/libraw",
                "*.so"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.libraw.org/data/LibRaw-0.22.0.tar.gz",
                    "sha256": "1071e6e8011593c366ffdadc3d3513f57c90202d526e133174945ec1dd53f2a1"
                },
                {
                    "type": "archive",
                    "url": "https://www.libraw.org/data/LibRaw-demosaic-pack-GPL2-0.18.8.tar.gz",
                    "sha256": "0b24bcf7bbb5d13fde58bb071f94dc9354be09bc44b2bba0698493065e99f8da",
                    "dest": "LibRaw-demosaic-pack-GPL2"
                },
                {
                    "type": "archive",
                    "url": "https://www.libraw.org/data/LibRaw-demosaic-pack-GPL3-0.18.8.tar.gz",
                    "sha256": "ffd6916cd66c8101e4e6b589799f256c897748d2fd2486aa34c3705146dbc701",
                    "dest": "LibRaw-demosaic-pack-GPL3"
                }
            ]
        },
        {
            "name": "librtprocess",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "cleanup": [
                "/lib/cmake"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/CarVac/librtprocess/archive/0.12.0.tar.gz",
                    "sha256": "ed6862b1491559e71dbebe8cbb299008fb16e230acf3bb9d42bd52942644c4d9"
                }
            ]
        },
        {
            "name": "filmulator",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/CarVac/filmulator-gui/archive/v0.12.0.tar.gz",
                    "sha256": "8f69d47f45234cd452ae6a864329a6c668845778aff84552d318ee977ddb2df2"
                },
                {
                    "type": "patch",
                    "paths": [
                        "patches/filmulator-appstream.patch",
                        "patches/filmulator-cxx-assert.patch",
                        "patches/filmulator-fixes.patch"
                    ]
                }
            ]
        }
    ]
}
