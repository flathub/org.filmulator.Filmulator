+<?xml version="1.0" encoding="UTF-8"?>
+<component type="desktop">
+ <id>org.filmulator.Filmulator</id>
+ <metadata_license>CC0</metadata_license>
+ <project_license>GPL-2.0+</project_license>
+ <name>Filmulator</name>
+ <summary>Simple raw photo editor based on film development</summary>
+ <developer id="org.filmulator">
+   <name>Filmulator Developers</name>
+ </developer>
+ <launchable type="desktop-id">filmulator.desktop</launchable>
+ <description>
+   <p>A GUI adaptation of Filmulator, a film emulator with all of the
+   positives and none of the negatives. Filmulator accepts raw files
+   from cameras and simulates the development of film as if exposed to
+   the same light as the camera's sensor.</p>
+ </description>
+ <screenshots>
+  <screenshot type="default">
+    <image>https://filmulator.org/images/screenshots/0.8_Filmulate_overview.png</image>
+   <caption>The Filmulator window</caption>
+  </screenshot>
+ </screenshots>
+ <url type="homepage">https://filmulator.org/</url>
